# Server
PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Cloudflare R2 (S3-compatible media storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sportclan-media
R2_PUBLIC_BASE_URL=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Firebase Admin (FCM)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# SMS via 2Factor.in (India)
TWOFACTOR_API_KEY=

# Razorpay (Payments)
# PAYMENTS_ENABLED gates all paid flows — leave unset/false until a live gateway
# is wired (mock order + no signature check otherwise). RAZORPAY_KEY_ID is the
# public key handed to the mobile SDK.
PAYMENTS_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# Auth / access control
# ALLOW_TEST_OTP: dev-only bypass accepting the fixed test OTP (123456) for any
# phone. MUST stay unset/false in production (also gated by NODE_ENV=production).
ALLOW_TEST_OTP=false
# ADMIN_USER_IDS: comma-separated user UUIDs granted admin access.
ADMIN_USER_IDS=
# CRON_SECRET: shared secret required (X-Cron-Secret header) to trigger the
# scheduled-job + account-purge endpoints. Fails closed when unset.
CRON_SECRET=

# App Version (Force Update)
APP_LATEST_VERSION=1.0.0
APP_MIN_VERSION=1.0.0
APP_FORCE_UPDATE=false
APP_STORE_URL=

# Sentry (Error Tracking)
SENTRY_DSN=

# Upstash Redis (Rate Limiting / Caching — future)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
